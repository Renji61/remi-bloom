# Database
DB_PASSWORD=change_me_to_a_long_random_password
DATABASE_URL=postgres://remi_bloom:change_me_to_a_long_random_password@localhost:5432/remi_bloom

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Optional: Set the URL for production (replace with your domain)
AUTH_URL=http://localhost:4131

# Production domain used by docker-compose.prod.yml and Caddy
DOMAIN=your-domain.com

# One-time seed endpoint secret. Generate with: openssl rand -base64 32
REMI_BLOOM_SEED_SECRET=your_seed_secret_here

# GHCR image tag used by docker-compose.prod.yml
REMI_BLOOM_IMAGE_TAG=latest
