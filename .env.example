# Database
DB_PASSWORD=change_me_to_a_long_random_password
DATABASE_URL=postgres://remi_bloom:change_me_to_a_long_random_password@localhost:5432/remi_bloom

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=your_auth_secret_here

# Public URL used by Auth.js. Include the port if exposing the app directly.
AUTH_URL=http://localhost:4131

# One-time seed endpoint secret. Generate with: openssl rand -base64 32
REMI_BLOOM_SEED_SECRET=your_seed_secret_here

# Set to "true" to disable public registration. New accounts can still be
# created via the /api/seed endpoint or by temporarily setting this to "false".
DISABLE_OPEN_REGISTRATION=false

# GHCR image tag used by docker-compose.prod.yml
REMI_BLOOM_IMAGE_TAG=latest

# Plant Identification APIs (Required for the Identify feature)
# Get a key from: https://plant.id/
PLANTID_API_KEY=your_plantid_api_key_here
# Get a key from: https://perenual.com/
PERENUAL_API_KEY=your_perenual_api_key_here

# OpenWeather API Key (Required for weather forecast and alerts)
# Get a key from: https://openweathermap.org/api
WEATHER_API_KEY=your_openweather_api_key_here

# Set to "false" to prevent users from overriding server API keys in
# Settings > API Keys. When disabled, the fields are shown but locked,
# and the server-configured env vars are always used.
# Defaults to "true" when unset.
API_KEYS_OVERRIDABLE=true
